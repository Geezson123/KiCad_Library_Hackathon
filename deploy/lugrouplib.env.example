# LuGroupLib server environment.
#
# Copy to /etc/lugrouplib.env, fill in, then lock it down:
#     sudo install -m 600 -o root -g root lugrouplib.env.example /etc/lugrouplib.env
#     sudo nano /etc/lugrouplib.env
#
# This file holds secrets. It must not be world-readable and must never be committed.

# --- Required -------------------------------------------------------------------
# Signs session cookies. Generate with:  python3 -c "import secrets;print(secrets.token_hex(32))"
# If unset the app picks a random key at startup, which signs everyone out on restart.
LUGROUPLIB_SECRET=

# --- Sign in with Slack ---------------------------------------------------------
# From https://api.slack.com/apps -> your app -> Basic Information / OAuth & Permissions.
# Leave blank to run without Slack (only useful alongside LUGROUPLIB_DEV_LOGIN).
LUGROUPLIB_SLACK_CLIENT_ID=
LUGROUPLIB_SLACK_CLIENT_SECRET=

# Restrict sign-in to one workspace. Find it in the Slack URL or via auth.test.
# Strongly recommended: without it, any Slack account anywhere can sign in.
LUGROUPLIB_SLACK_TEAM_ID=

# Slack user IDs (comma-separated) made master librarian on first sign-in.
# Needed once, to bootstrap: the first user has nobody to promote them.
LUGROUPLIB_LIBRARIANS=

# --- TLS ------------------------------------------------------------------------
# Set to 1 once the site is served over HTTPS, so session cookies are marked Secure.
LUGROUPLIB_HTTPS=1

# --- Optional features ----------------------------------------------------------
# Free key from https://www.mouser.com/api-hub/ — enables "Add from Mouser link".
LUGROUPLIB_MOUSER_KEY=

# Enables AI metadata drafting and receipt reading. Without it both degrade gracefully.
ANTHROPIC_API_KEY=

# --- Never set this on a reachable server ---------------------------------------
# Passwordless sign-in as any name. Only for a machine nobody else can reach.
# LUGROUPLIB_DEV_LOGIN=1
